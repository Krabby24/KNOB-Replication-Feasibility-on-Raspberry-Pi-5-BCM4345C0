*.py[cod]
*.pyo
*.pyd
*.egg-info/
.venv/
venv/
env/

# OS / editor files
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
*.old
*.tmp
*.bak

# Bluetooth captures and packet traces
*.pcap
*.pcapng
*.btsnoop
*btsnoop*
*lmp_capture*
*lmp_monitor*
*btmon*

# Raw memory dumps / firmware dumps
*.bin
*.dump
*.raw
*.mem
*.hexdump
ram_*.txt
ram_*.log
bcm4345_ram*

# Large generated artifacts
*.zip
*.tar
*.tar.gz
*.7z

# LaTeX / Overleaf build artifacts
*.aux
*.bbl
*.blg
*.log
*.out
*.toc
*.lof
*.lot
*.fls
*.fdb_latexmk
*.synctex.gz
